# Frontend (safe to expose in the browser bundle — protected by RLS, not secrecy)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Used only by scripts run locally (e.g. drizzle-kit generate/migrate), never bundled into the app
DATABASE_URL=postgresql://postgres:password@db.xxxxxxxx.supabase.co:5432/postgres

# --- Everything below is set via `supabase secrets set` / the Supabase dashboard, ---
# --- NOT in this file. Listed here only for reference.                           ---
# SUPABASE_URL                  (auto-injected into edge functions)
# SUPABASE_ANON_KEY             (auto-injected into edge functions)
# SUPABASE_SERVICE_ROLE_KEY     (auto-injected into edge functions)
# MTALKZ_API_KEY                (supabase secrets set MTALKZ_API_KEY=...)
# MTALKZ_SENDER_ID              (supabase secrets set MTALKZ_SENDER_ID=...)
